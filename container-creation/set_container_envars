echo "Setting container environment variables"

# User-maintained options

## Container home directories

## Distrobox has the option to allocate a separate home directory for
## the container, to avoid conflicts with the host configuration files
## that are usually hidden "dotfiles." This is especially useful when
## the host and container run different Linux distros, as is the case
## on my main environment.

## The environment variable that controls this is called 
## `DBX_CONTAINER_HOME_PREFIX`. You can put this anywhere you have
## read and write permissions. I put it in `$HOME/dbx-homes` to
## make moving between the container and host homes easy.

export DBX_CONTAINER_HOME_PREFIX="$HOME/dbx-homes"

## Container manager

## Distrobox can use either Podman or Docker. I use Podman, but
## if you want to use Docker, install Docker on your host and then
## change `podman` to `docker`.

export DBX_CONTAINER_MANAGER="podman"

# ** You should not need to change anything below here **

## `COMPUTE_MODE`

## R-AI-D can build two types of containers:
##
## 1. COMPUTE_MODE=CPU - only the CPU will be used, and
## 2. COMPUTE_MODE=CUDA - the CPU and an NVIDIA GPU will be used.

## If the scripts detect the existence of the `nvidia-smi` program
## *and* the architecture is `x86_64`, `COMPUTE_MODE` will be set to
## `CUDA`; otherwise it will be set to `CPU`.
export ARCH="$(uname -m)"
echo "ARCH: $ARCH"

if [[ \
  "$ARCH" != "x86_64" \
  || "$(which nvidia-smi | wc -l)" == "0" \
  ]]
then
  export COMPUTE_MODE="CPU"

else
  export COMPUTE_MODE="CUDA"

fi

echo "COMPUTE_MODE: $COMPUTE_MODE"

## containerfile name
export CONTAINERFILE="Containerfile.base"

## Distrobox
export DBX_CONTAINER_NAME="R-AI-D-$COMPUTE_MODE"
export DBX_CONTAINER_IMAGE="localhost/r-ai-d-base:latest"
export DBX_CONTAINER_DIRECTORY="$DBX_CONTAINER_HOME_PREFIX/$DBX_CONTAINER_NAME"
export DBX_NON_INTERACTIVE=true

## Desktop folders
export LOCALBIN=$HOME/.local/bin; mkdir --parents $LOCALBIN
export LOGFILES=$HOME/Logfiles; mkdir --parents $LOGFILES
export PROJECTS=$HOME/Projects; mkdir --parents $PROJECTS

if [[ ! "$PATH" =~ "$HOME/.local/bin" ]]
then
  echo "Prepending $LOCALBIN to \$PATH"
  export PATH="$HOME/.local/bin:$PATH"

fi

## Container entry script
export ENTRY_SCRIPT=$LOCALBIN/$DBX_CONTAINER_NAME
