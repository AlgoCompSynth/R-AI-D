echo "Setting environment variables"

# Desktop folders
export LOCALBIN=$HOME/.local/bin
export LOGFILES=$HOME/Logfiles
export PROJECTS=$HOME/Projects
export SCRIPTS=$HOME/Scripts

if [[ ! "$PATH" =~ "$HOME/.local/bin" ]]
then
  echo "Prepending $LOCALBIN to \$PATH"
  export PATH="$HOME/.local/bin:$PATH"

fi

# image and container names
export CONTAINER_NAME="xen-assist"
export BASE_CONTAINERFILE="Containerfile.base"
export BASE_IMAGE_TAG="localhost/xen-assist-base:latest"
export SERVER_CONTAINERFILE="Containerfile.server"
export SERVER_IMAGE_TAG="localhost/xen-assist-server:latest"

# you can change this but it needs to be writeable for you
export OLLAMA_MODELS_HOST="/home/data/.ollama"
export OLLAMA_MODELS_CONTAINER="/usr/share/ollama/.ollama"

# Distrobox
export DBX_CONTAINER_MANAGER="podman"
export DBX_CONTAINER_NAME="xen-assist"
export DBX_CONTAINER_IMAGE="localhost/xen-assist-base:latest"
export DBX_CONTAINER_HOME_PREFIX="$HOME/dbx-homes"
export DBX_CONTAINER_DIRECTORY="$DBX_CONTAINER_HOME_PREFIX/$DBX_CONTAINER_NAME"
export DBX_NON_INTERACTIVE=true

export ENTRY_SCRIPT=$LOCALBIN/$DBX_CONTAINER_NAME
