# https://github.com/containers/toolbox/blob/main/images/ubuntu/24.04/Containerfile
FROM quay.io/toolbx/ubuntu-toolbox:24.04
LABEL maintainer="M. Edward (Ed) Borasky <znmeb@algocompsynth.com>"

# set aside a script / logfile depository
USER root
ENV WORKDIR=/usr/local/src/workdir
WORKDIR $WORKDIR
RUN cat /etc/resolv.conf # check DNS settings

# Environment variables
COPY set_container_envars ./

# R-AI-D base
COPY installers/r-ai-d-base.sh ./
RUN ./r-ai-d-base.sh \
  2>&1 | gzip -9c > $WORKDIR/r-ai-d-base.log.gz

# Quarto
COPY installers/quarto.sh ./
RUN /usr/bin/time ./quarto.sh \
  2>&1 | gzip -9c > $WORKDIR/quarto.log.gz

# Faust
COPY installers/faust.sh ./
RUN /usr/bin/time ./faust.sh \
  2>&1 | gzip -9c > $WORKDIR/faust.log.gz

# R developer packages
COPY installers/developer-packages.R ./
RUN /usr/bin/time ./developer-packages.R \
  2>&1 | gzip -9c > $WORKDIR/developer-packages.log.gz

# R AI packages
COPY installers/ai-packages.R ./
RUN /usr/bin/time ./ai-packages.R \
  2>&1 | gzip -9c > $WORKDIR/ai-packages.log.gz

# R audio packages
COPY installers/audio-packages.R ./
RUN /usr/bin/time ./audio-packages.R \
  2>&1 | gzip -9c > $WORKDIR/audio-packages.log.gz

# Ollama
COPY installers/ollama.sh ./
RUN /usr/bin/time ./ollama.sh \
  2>&1 | gzip -9c > $WORKDIR/ollama.log.gz
